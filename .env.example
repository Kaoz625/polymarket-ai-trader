# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB credentials
POLY_API_KEY=your_poly_api_key_here
POLY_API_SECRET=your_poly_api_secret_here
POLY_API_PASSPHRASE=your_poly_passphrase_here
